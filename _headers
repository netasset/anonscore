/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  X-XSS-Protection: 1; mode=block
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self' https://blockstream.info https://mempool.space https://anonscore-ai.netassetpremium.workers.dev; img-src 'self' data: blob:; base-uri 'self'; form-action 'none'; object-src 'none'; frame-ancestors 'none'

# Self-hosted libraries are stable — cache hard.
/vendor/*
  Cache-Control: public, max-age=31536000, immutable

/og.png
  Cache-Control: public, max-age=2592000

# Service worker: must always be re-checked so a new deploy actually rolls out.
/sw.js
  Cache-Control: no-cache, max-age=0, must-revalidate
